generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model School {
  id         Int      @id @default(autoincrement())
  name       String
  school_id  Int      @unique
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  users    User[]
  students Student[]

  @@map("schools")
}

model User {
  id         Int      @id @default(autoincrement())
  email      String   @unique
  password   String
  role       String   @default("STUDENT")
  school_id  Int
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  school School @relation(fields: [school_id], references: [id])

  @@index([school_id])
  @@map("users")
}

model Student {
  id         Int      @id @default(autoincrement())
  name       String
  dob        DateTime?
  class_id   Int?
  school_id  Int
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  school School @relation(fields: [school_id], references: [id])

  @@index([school_id])
  @@map("students")
}

model Subject {
  id          Int      @id @default(autoincrement())
  name        String
  group       String
  coefficient Int
  school_id   Int
  grades      Grade[]

  @@index([school_id])
  @@map("subjects")
}

model Grade {
  id         Int      @id @default(autoincrement())
  value      Float
  student_id Int
  subject_id Int
  trimester  Int
  school_id  Int
  
  subject    Subject  @relation(fields: [subject_id], references: [id])

  @@index([school_id])
  @@index([student_id])
  @@index([subject_id])
  @@map("grades")
}

model TeacherSubject {
  id         Int      @id @default(autoincrement())
  teacher_id Int
  subject_id Int
  class_id   Int
  school_id  Int
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([school_id])
  @@map("teacher_subjects")
}

model AttendanceSession {
  id           Int      @id @default(autoincrement())
  class_id     Int
  subject_id   Int
  teacher_id   Int
  timetable_id Int
  date         DateTime
  school_id    Int
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@index([school_id])
  @@map("attendance_sessions")
}

model Attendance {
  id         Int      @id @default(autoincrement())
  student_id Int
  status     String
  session_id Int
  version    Int      @default(1)
  school_id  Int
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([school_id])
  @@index([session_id])
  @@map("attendances")
}

model Payment {
  id             Int      @id @default(autoincrement())
  amount_fcfa    Int
  receipt_number String
  receipt_hash   String
  status         String
  school_id      Int
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  @@index([school_id])
  @@map("payments")
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  action     String
  data       Json?
  school_id  Int
  created_at DateTime @default(now())

  @@index([school_id])
  @@map("audit_logs")
}

model Note {
  id         Int      @id @default(autoincrement())
  content    String
  version    Int      @default(1)
  school_id  Int
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([school_id])
  @@map("notes")
}

model RefreshToken {
  id         Int       @id @default(autoincrement())
  token      String    @unique
  user_id    Int
  expires_at DateTime?
  created_at DateTime  @default(now())

  @@map("refresh_tokens")
}

model Timetable {
  id         Int      @id @default(autoincrement())
  class_id   Int
  teacher_id Int
  subject_id Int
  slot       String
  school_id  Int
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([school_id])
  @@map("timetables")
}

model SyncOperation {
  id                  Int      @id @default(autoincrement())
  client_operation_id String   @unique
  entity              String
  entity_id           Int
  payload             Json
  school_id           Int
  created_at          DateTime @default(now())

  @@index([school_id])
  @@map("sync_operations")
}
