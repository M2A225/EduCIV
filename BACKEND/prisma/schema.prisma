generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model School {
  id         Int      @id @default(autoincrement())
  name       String
  school_id  String   @unique
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("schools")
}

model User {
  id         Int      @id @default(autoincrement())
  email      String   @unique
  password   String
  school_id  String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("users")
}

model Student {
  id         Int      @id @default(autoincrement())
  name       String
  school_id  String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("students")
}

model TeacherSubject {
  id         Int      @id @default(autoincrement())
  teacher_id String
  subject_id String
  class_id   String
  school_id  String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("teacher_subjects")
}

model AttendanceSession {
  id           Int      @id @default(autoincrement())
  class_id     String
  subject_id   String
  teacher_id   String
  timetable_id String
  date         String
  school_id    String
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@map("attendance_sessions")
}

model Attendance {
  id         Int      @id @default(autoincrement())
  student_id String
  status     String
  session_id Int
  version    Int      @default(1)
  school_id  String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("attendances")
}

model Payment {
  id             Int      @id @default(autoincrement())
  amount_fcfa    Int
  receipt_number String
  receipt_hash   String
  status         String
  school_id      String
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  @@map("payments")
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  action     String
  data       Json?
  school_id  String
  created_at DateTime @default(now())

  @@map("audit_logs")
}

model Note {
  id         Int      @id @default(autoincrement())
  content    String
  version    Int      @default(1)
  school_id  String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("notes")
}

model RefreshToken {
  id         Int       @id @default(autoincrement())
  token      String    @unique
  user_id    Int
  expires_at DateTime?
  created_at DateTime  @default(now())

  @@map("refresh_tokens")
}

model Timetable {
  id         Int      @id @default(autoincrement())
  class_id   String
  teacher_id String
  subject_id String
  slot       String
  school_id  String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("timetables")
}

model SyncOperation {
  id                  Int      @id @default(autoincrement())
  client_operation_id String   @unique
  entity              String
  entity_id           String
  payload             String
  school_id           String
  created_at          DateTime @default(now())

  @@map("sync_operations")
}
