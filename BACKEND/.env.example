# Application
NODE_ENV=production
PORT=3000
CORS_ORIGIN=https://app.educiv.com

# Database (PostgreSQL via Prisma)
DATABASE_URL="postgresql://user:password@localhost:5432/educiv?schema=public"

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRES=15m
REFRESH_EXPIRES=7d

# Redis (Upstash Redis via REST)
REDIS_HOST=your-region.upstash.io
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password
REDIS_ATTEMPT_TTL=900
REDIS_ATTEMPT_THRESHOLD=5

# Upstash Redis (REST API)
UPSTASH_REDIS_HOST=your-region.upstash.io
UPSTASH_REDIS_PORT=6379
UPSTASH_REDIS_PASSWORD=your-redis-password

# Rate Limiting (Throttler + Redis fallback)
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Rate Limiting Custom (Auth)
REDIS_ATTEMPT_TTL=900
REDIS_ATTEMPT_THRESHOLD=5

# Sentry (Error Tracking)
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# Email (Optional - for notifications)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-email-password
SMTP_FROM=noreply@educiv.com

# Frontend URL (for CORS, password reset links, etc.)
FRONTEND_URL=https://app.educiv.com