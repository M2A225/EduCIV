<UserControl x:Class="EduCIV.App.Views.LoginPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1100"
             Background="{DynamicResource ColorBg}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Left Brand Panel -->
        <Border Grid.Column="0" Background="{DynamicResource ColorPrimaryBrush}" Padding="60">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo -->
                <StackPanel Grid.Row="0" Margin="0,0,0,48">
                    <TextBlock Text="EduCIV" FontSize="32" FontWeight="Bold"
                               FontFamily="{DynamicResource FontHeading}"
                               Foreground="White"/>
                    <TextBlock Text="Gestion Scolaire" FontSize="16"
                               Foreground="White" Opacity="0.8"/>
                </StackPanel>

                <!-- Tagline + Stats -->
                <StackPanel Grid.Row="1" VerticalAlignment="Center">
                    <TextBlock Text="Gechez votre etablissement avec intelligence"
                               FontSize="28" FontWeight="Bold" FontFamily="{DynamicResource FontHeading}"
                               Foreground="White" TextWrapping="Wrap" Margin="0,0,0,40"/>

                    <Grid Margin="0,0,0,32">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="10k+" FontSize="24" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="Utilisateurs" FontSize="13" Foreground="White" Opacity="0.7"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="500+" FontSize="24" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="Etablissements" FontSize="13" Foreground="White" Opacity="0.7"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="99.9%" FontSize="24" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="Disponibilite" FontSize="13" Foreground="White" Opacity="0.7"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <!-- Footer -->
                <TextBlock Grid.Row="2" Text="2026 EduCIV. Tous droits reserves."
                           FontSize="12" Foreground="White" Opacity="0.5"/>
            </Grid>
        </Border>

        <!-- Right Login Form -->
        <Border Grid.Column="1" Width="440" Background="{DynamicResource ColorBgElevated}"
                BorderBrush="{DynamicResource ColorBorder}" BorderThickness="1,0,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="48" VerticalAlignment="Center">
                    <TextBlock Text="Bienvenue" FontSize="28" FontWeight="Bold"
                               FontFamily="{DynamicResource FontHeading}"
                               Foreground="{DynamicResource ColorText}" Margin="0,0,0,4"/>
                    <TextBlock Text="Connectez-vous a votre espace" FontSize="14"
                               Foreground="{DynamicResource ColorTextSecondary}" Margin="0,0,0,32"/>

                    <!-- Identifier -->
                    <TextBlock Text="Email ou telephone" FontSize="13"
                               Foreground="{DynamicResource ColorTextSecondary}" Margin="0,0,0,6"/>
                    <TextBox x:Name="IdentifierBox"
                             Text="{Binding Identifier, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource ModernTextBox}"
                             Margin="0,0,0,20"/>

                    <!-- Password with toggle -->
                    <TextBlock Text="Mot de passe" FontSize="13"
                               Foreground="{DynamicResource ColorTextSecondary}" Margin="0,0,0,6"/>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <PasswordBox x:Name="PasswordBox"
                                     x:FieldModifier="public"
                                     Style="{DynamicResource ModernPasswordBox}"
                                     Grid.Column="0"/>
                        <TextBox x:Name="PasswordVisibleBox"
                                 Style="{DynamicResource ModernTextBox}"
                                 Grid.Column="0"
                                 Visibility="Collapsed"/>
                        <Button x:Name="TogglePasswordBtn"
                                Grid.Column="1" Content="Afficher"
                                Style="{DynamicResource GhostButton}"
                                Click="TogglePassword_Click"
                                VerticalAlignment="Center" Margin="4,0,0,0"
                                FontSize="12" Width="60"/>
                    </Grid>

                    <!-- Forgot password -->
                    <TextBlock Margin="0,0,0,24">
                        <Run Text="Mot de passe oublie ?" FontSize="13"
                             Foreground="{DynamicResource ColorPrimaryBrush}"
                             Cursor="Hand"/>
                    </TextBlock>

                    <!-- Login button -->
                    <Button x:Name="LoginButton" Content="Se connecter"
                            Style="{DynamicResource PrimaryButton}"
                            Click="LoginButton_Click" IsDefault="True"
                            Margin="0,0,0,12"/>

                    <!-- Loading -->
                    <Border Background="{DynamicResource ColorPrimaryBgBrush}"
                            CornerRadius="10" Height="40"
                            Visibility="{Binding LoadingVisibility}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="Connexion en cours..." FontSize="13"
                                       Foreground="{DynamicResource ColorPrimaryBrush}"/>
                        </StackPanel>
                    </Border>

                    <!-- Error message -->
                    <Border Background="{DynamicResource ColorErrorBgBrush}"
                            CornerRadius="10" Padding="16,10" Margin="0,8,0,0"
                            Visibility="{Binding ErrorMessageVisibility}">
                        <TextBlock Text="{Binding ErrorMessage}"
                                   Foreground="{DynamicResource ColorErrorBrush}"
                                   FontSize="13" TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
