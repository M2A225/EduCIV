<UserControl x:Class="EduCIV.App.Views.NotesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900"
             Background="{DynamicResource ColorBg}">
    <UserControl.Resources>
        <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Padding" Value="12,6"/>
        </Style>
    </UserControl.Resources>
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="Notes" FontSize="28" FontWeight="Bold" FontFamily="{DynamicResource FontHeading}" Foreground="{DynamicResource ColorText}" VerticalAlignment="Center"/>
            <Button Content="➕ Nouvelle note" Command="{Binding AddGradeCommand}" Style="{StaticResource PrimaryButton}" Margin="16,0,0,0" VerticalAlignment="Center"/>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource ModernCard}" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DataGrid Grid.Row="0" ItemsSource="{Binding Grades}" 
                          SelectedItem="{Binding SelectedGrade, Mode=TwoWay}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          HeadersVisibility="Column" CanUserSortColumns="True"
                          CanUserResizeColumns="True" SelectionMode="Single"
                          RowHeaderWidth="0" GridLinesVisibility="Horizontal"
                          Background="Transparent" BorderThickness="0"
                          VerticalGridLinesBrush="{DynamicResource ColorBorder}"
                          HorizontalGridLinesBrush="{DynamicResource ColorBorder}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Élève" Binding="{Binding StudentName}" Width="*"/>
                        <DataGridTextColumn Header="Matière" Binding="{Binding SubjectName}" Width="120"/>
                        <DataGridTextColumn Header="Note" Binding="{Binding Value}" Width="80">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Coefficient" Binding="{Binding Coefficient}" Width="80"/>
                        <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="100"/>
                        <DataGridTextColumn Header="Date" Binding="{Binding CreatedAt, StringFormat={}{0:dd/MM/yyyy}}" Width="100"/>
                        <DataGridTemplateColumn Header="Actions" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button Content="✏️" Command="{Binding DataContext.EditGradeCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                                CommandParameter="{Binding}" Style="{StaticResource GhostButton}" Width="28" Height="28"/>
                                        <Button Content="🗑️" Command="{Binding DataContext.DeleteGradeCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                                CommandParameter="{Binding}" Style="{StaticResource GhostButton}" Width="28" Height="28"
                                                Foreground="{DynamicResource ColorErrorBrush}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <Border Grid.Row="1" Visibility="{Binding IsEditMode, Converter={StaticResource BooleanToVisibilityConverter}}"
                        Background="{DynamicResource ColorSurface}" BorderBrush="{DynamicResource ColorBorder}" BorderThickness="0,1,0,0" Padding="16" Margin="16">
                    <StackPanel>
                        <TextBlock Text="Nouvelle note" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource ColorText}" Margin="0,0,0,16"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBox Grid.Row="0" Grid.Column="0" Text="{Binding SelectedGrade.StudentId, Mode=TwoWay}" Style="{StaticResource ModernTextBox}" Tag="ID Élève" Margin="0,0,8,8"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding SelectedGrade.SubjectId, Mode=TwoWay}" Style="{StaticResource ModernTextBox}" Tag="ID Matière" Margin="8,0,0,8"/>
                            <TextBox Grid.Row="1" Grid.Column="0" Text="{Binding SelectedGrade.Value, Mode=TwoWay}" Style="{StaticResource ModernTextBox}" Tag="Note" Margin="0,0,8,8"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding SelectedGrade.Coefficient, Mode=TwoWay}" Style="{StaticResource ModernTextBox}" Tag="Coefficient" Margin="8,0,0,8"/>
                            <TextBox Grid.Row="2" Grid.ColumnSpan="2" Text="{Binding SelectedGrade.Comment, Mode=TwoWay}" Style="{StaticResource ModernTextBox}" Tag="Commentaire" Margin="0,0,0,8"/>

                            <StackPanel Grid.Row="3" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                                <Button Content="Annuler" Command="{Binding CancelCommand}" Style="{StaticResource SecondaryButton}"/>
                                <Button Content="Enregistrer" Command="{Binding SaveGradeCommand}" Style="{StaticResource PrimaryButton}" Margin="8,0,0,0"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
