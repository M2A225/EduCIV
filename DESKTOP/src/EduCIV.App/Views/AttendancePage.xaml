<UserControl x:Class="EduCIV.App.Views.AttendancePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900"
             Background="{DynamicResource ColorBg}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="Présences" FontSize="28" FontWeight="Bold" FontFamily="{DynamicResource FontHeading}" Foreground="{DynamicResource ColorText}"/>
            <Button Content="➕ Nouvelle séance" Command="{Binding AddSessionCommand}" Style="{StaticResource PrimaryButton}" Margin="24,0,0,0" VerticalAlignment="Center"/>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource ModernCard}" Margin="0,0,0,16" Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Séances" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource ColorText}" VerticalAlignment="Center" Margin="0,0,16,0"/>
                <ListView Grid.Column="1" ItemsSource="{Binding Sessions}" SelectedItem="{Binding SelectedSession, Mode=TwoWay}"
                          Background="Transparent" BorderThickness="0" Height="120">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="8,4" Margin="0,2">
                                <TextBlock Text="{Binding Date, StringFormat={}{0:dd/MM/yyyy}}" Foreground="{DynamicResource ColorText}"/>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource ModernCard}" Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="Appel" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource ColorText}" VerticalAlignment="Center"/>
                    <Button Content="Enregistrer" Command="{Binding SaveSessionCommand}" Style="{StaticResource PrimaryButton}" Margin="16,0,0,0" Padding="16,6" VerticalAlignment="Center"/>
                    <Button Content="Marquer présence" Command="{Binding MarkAttendanceCommand}" CommandParameter="{Binding SelectedSession}" 
                            Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Padding="16,6" VerticalAlignment="Center"/>
                </StackPanel>

                <DataGrid Grid.Row="1" ItemsSource="{Binding Records}" 
                          AutoGenerateColumns="False" IsReadOnly="False"
                          HeadersVisibility="Column" CanUserSortColumns="True"
                          CanUserResizeColumns="True" SelectionMode="Single"
                          RowHeaderWidth="0" GridLinesVisibility="Horizontal"
                          Background="Transparent" BorderThickness="0"
                          VerticalGridLinesBrush="{DynamicResource ColorBorder}"
                          HorizontalGridLinesBrush="{DynamicResource ColorBorder}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Élève" Binding="{Binding StudentName}" Width="*" IsReadOnly="True"/>
                        <DataGridTemplateColumn Header="Statut" Width="110">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border>
                                        <Border.Style>
                                            <Style TargetType="Border" BasedOn="{StaticResource Badge}">
                                                <Setter Property="Background" Value="{DynamicResource ColorSurface}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="PRESENT">
                                                        <Setter Property="Background" Value="{DynamicResource ColorSuccessBgBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="ABSENT">
                                                        <Setter Property="Background" Value="{DynamicResource ColorErrorBgBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="LATE">
                                                        <Setter Property="Background" Value="{DynamicResource ColorWarningBgBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding Status}" FontSize="11" FontWeight="SemiBold" FontFamily="{StaticResource FontSans}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource ColorTextSecondary}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="PRESENT">
                                                            <Setter Property="Foreground" Value="{DynamicResource ColorSuccessTextBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="ABSENT">
                                                            <Setter Property="Foreground" Value="{DynamicResource ColorErrorTextBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="LATE">
                                                            <Setter Property="Foreground" Value="{DynamicResource ColorWarningTextBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Heure arrivée" Binding="{Binding ArrivalTime}" Width="100"/>
                        <DataGridTextColumn Header="Commentaire" Binding="{Binding Comment}" Width="*"/>
                        <DataGridTemplateColumn Header="Actions" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="✅" Command="{Binding DataContext.MarkAttendanceCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                            CommandParameter="{Binding}" Style="{StaticResource GhostButton}" Width="28" Height="28"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
