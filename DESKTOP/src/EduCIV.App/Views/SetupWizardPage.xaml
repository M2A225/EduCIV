<UserControl x:Class="EduCIV.App.Views.SetupWizardPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:EduCIV.App.Views"
             xmlns:viewmodels="clr-namespace:EduCIV.App.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900">
    <Grid Background="#F5F5F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" Padding="24,16"
                Effect="{Binding Source={x:Null}}">
            <StackPanel>
                <TextBlock Text="Configuration initiale" FontSize="22" FontWeight="Bold"
                           Foreground="#333"/>
                <ItemsControl ItemsSource="{Binding MaxSteps}" Margin="0,12,0,0">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="40" Height="40" CornerRadius="20"
                                    Background="#E0E0E0" Margin="4,0">
                                <TextBlock Text="{Binding}" HorizontalAlignment="Center"
                                           VerticalAlignment="Center" FontWeight="Bold"
                                           Foreground="#666"/>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <ContentControl Grid.Row="1" Content="{Binding CurrentStep}">
            <ContentControl.Style>
                <Style TargetType="ContentControl">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding CurrentStep}" Value="1">
                            <Setter Property="ContentTemplate">
                                <Setter.Value>
                                    <DataTemplate>
                                        <StackPanel Margin="24" VerticalAlignment="Center">
                                            <TextBlock Text="Etape 1 : Informations de l ecole" FontSize="18"
                                                       FontWeight="Bold" Margin="0,0,0,16"/>
                                            <TextBlock Text="Nom de l ecole" Foreground="#555" Margin="0,0,0,4"/>
                                            <TextBox Text="{Binding SchoolName}" Padding="10,8"
                                                     FontSize="14" Margin="0,0,0,12" BorderBrush="#CCC"/>
                                            <TextBlock Text="Adresse" Foreground="#555" Margin="0,0,0,4"/>
                                            <TextBox Text="{Binding SchoolAddress}" Padding="10,8"
                                                     FontSize="14" Margin="0,0,0,12" BorderBrush="#CCC"/>
                                            <TextBlock Text="Telephone" Foreground="#555" Margin="0,0,0,4"/>
                                            <TextBox Text="{Binding SchoolPhone}" Padding="10,8"
                                                     FontSize="14" Margin="0,0,0,12" BorderBrush="#CCC"/>
                                            <TextBlock Text="Email" Foreground="#555" Margin="0,0,0,4"/>
                                            <TextBox Text="{Binding SchoolEmail}" Padding="10,8"
                                                     FontSize="14" BorderBrush="#CCC"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding CurrentStep}" Value="2">
                            <Setter Property="ContentTemplate">
                                <Setter.Value>
                                    <DataTemplate>
                                        <StackPanel Margin="24" VerticalAlignment="Center">
                                            <TextBlock Text="Etape 2 : Directeur" FontSize="18"
                                                       FontWeight="Bold" Margin="0,0,0,16"/>
                                            <TextBlock Text="Prenom" Foreground="#555" Margin="0,0,0,4"/>
                                            <TextBox Text="{Binding DirectorFirstName}" Padding="10,8"
                                                     FontSize="14" Margin="0,0,0,12" BorderBrush="#CCC"/>
                                            <TextBlock Text="Nom" Foreground="#555" Margin="0,0,0,4"/>
                                            <TextBox Text="{Binding DirectorLastName}" Padding="10,8"
                                                     FontSize="14" Margin="0,0,0,12" BorderBrush="#CCC"/>
                                            <TextBlock Text="Email" Foreground="#555" Margin="0,0,0,4"/>
                                            <TextBox Text="{Binding DirectorEmail}" Padding="10,8"
                                                     FontSize="14" Margin="0,0,0,12" BorderBrush="#CCC"/>
                                            <TextBlock Text="Mot de passe" Foreground="#555" Margin="0,0,0,4"/>
                                            <PasswordBox Padding="10,8" FontSize="14" BorderBrush="#CCC"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ContentControl.Style>
        </ContentControl>

        <Border Grid.Row="2" Background="White" Padding="24,12"
                Effect="{Binding Source={x:Null}}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Retour" Command="{Binding BackCommand}"
                        Background="#E0E0E0" Foreground="#333" BorderThickness="0"
                        Padding="16,8" FontSize="14" Cursor="Hand" Margin="0,0,8,0"/>
                <Button Content="Suivant" Command="{Binding NextCommand}"
                        Background="#1976D2" Foreground="White" BorderThickness="0"
                        Padding="16,8" FontSize="14" Cursor="Hand" Margin="0,0,8,0"/>
                <Button Content="Terminer" Command="{Binding CompleteCommand}"
                        Background="#388E3C" Foreground="White" BorderThickness="0"
                        Padding="16,8" FontSize="14" Cursor="Hand"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
