<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- Backgrounds -->
  <SolidColorBrush x:Key="ColorBg" Color="#FAFAFA" />
  <SolidColorBrush x:Key="ColorBgElevated" Color="#FFFFFF" />
  <SolidColorBrush x:Key="ColorSurface" Color="#F3F4F6" />
  <SolidColorBrush x:Key="ColorSurfaceHover" Color="#E5E7EB" />

  <!-- Borders -->
  <SolidColorBrush x:Key="ColorBorder" Color="#E5E7EB" />
  <SolidColorBrush x:Key="ColorBorderStrong" Color="#D1D5DB" />
  <SolidColorBrush x:Key="ColorBorderFocus" Color="#7C3AED" />

  <!-- Text -->
  <SolidColorBrush x:Key="ColorText" Color="#111827" />
  <SolidColorBrush x:Key="ColorTextSecondary" Color="#4B5563" />
  <SolidColorBrush x:Key="ColorTextMuted" Color="#9CA3AF" />
  <SolidColorBrush x:Key="ColorTextInverse" Color="#FFFFFF" />

  <!-- Brand Brushes -->
  <SolidColorBrush x:Key="ColorPrimaryBrush" Color="#7C3AED" />
  <SolidColorBrush x:Key="ColorPrimaryHoverBrush" Color="#6D28D9" />
  <SolidColorBrush x:Key="ColorPrimaryLightBrush" Color="#A78BFA" />
  <SolidColorBrush x:Key="ColorPrimaryBgBrush" Color="#F3E8FF" />

  <SolidColorBrush x:Key="ColorCtaBrush" Color="#F97316" />
  <SolidColorBrush x:Key="ColorCtaHoverBrush" Color="#EA580C" />
  <SolidColorBrush x:Key="ColorCtaLightBrush" Color="#FB923C" />
  <SolidColorBrush x:Key="ColorCtaBgBrush" Color="#FFF7ED" />

  <!-- Semantic Brushes -->
  <SolidColorBrush x:Key="ColorSuccessBrush" Color="#10B981" />
  <SolidColorBrush x:Key="ColorSuccessBgBrush" Color="#ECFDF5" />
  <SolidColorBrush x:Key="ColorSuccessTextBrush" Color="#065F46" />
  <SolidColorBrush x:Key="ColorWarningBrush" Color="#F59E0B" />
  <SolidColorBrush x:Key="ColorWarningBgBrush" Color="#FFFBEB" />
  <SolidColorBrush x:Key="ColorWarningTextBrush" Color="#92400E" />
  <SolidColorBrush x:Key="ColorErrorBrush" Color="#EF4444" />
  <SolidColorBrush x:Key="ColorErrorBgBrush" Color="#FEF2F2" />
  <SolidColorBrush x:Key="ColorErrorTextBrush" Color="#991B1B" />
  <SolidColorBrush x:Key="ColorInfoBrush" Color="#3B82F6" />
  <SolidColorBrush x:Key="ColorInfoBgBrush" Color="#EFF6FF" />
  <SolidColorBrush x:Key="ColorInfoTextBrush" Color="#1E40AF" />

  <!-- Overlay -->
  <SolidColorBrush x:Key="ColorOverlay" Color="#000000" Opacity="0.5" />

</ResourceDictionary>
