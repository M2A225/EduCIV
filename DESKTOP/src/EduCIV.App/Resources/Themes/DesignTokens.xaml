<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

  <!-- Brand Colors -->
  <Color x:Key="ColorPrimary">#7C3AED</Color>
  <Color x:Key="ColorPrimaryHover">#6D28D9</Color>
  <Color x:Key="ColorPrimaryLight">#A78BFA</Color>
  <Color x:Key="ColorPrimaryBg">#F3E8FF</Color>

  <Color x:Key="ColorCta">#F97316</Color>
  <Color x:Key="ColorCtaHover">#EA580C</Color>
  <Color x:Key="ColorCtaLight">#FB923C</Color>
  <Color x:Key="ColorCtaBg">#FFF7ED</Color>

  <!-- Semantic Colors -->
  <Color x:Key="ColorSuccess">#10B981</Color>
  <Color x:Key="ColorSuccessHover">#059669</Color>
  <Color x:Key="ColorSuccessBg">#ECFDF5</Color>

  <Color x:Key="ColorWarning">#F59E0B</Color>
  <Color x:Key="ColorWarningHover">#D97706</Color>
  <Color x:Key="ColorWarningBg">#FFFBEB</Color>

  <Color x:Key="ColorError">#EF4444</Color>
  <Color x:Key="ColorErrorHover">#DC2626</Color>
  <Color x:Key="ColorErrorBg">#FEF2F2</Color>

  <Color x:Key="ColorInfo">#3B82F6</Color>
  <Color x:Key="ColorInfoHover">#2563EB</Color>
  <Color x:Key="ColorInfoBg">#EFF6FF</Color>

  <!-- Typography -->
  <FontFamily x:Key="FontSans">pack://application:,,,/Resources/#Geist</FontFamily>
  <FontFamily x:Key="FontMono">pack://application:,,,/Resources/#Geist Mono</FontFamily>
  <FontFamily x:Key="FontHeading">pack://application:,,,/Resources/#Geist</FontFamily>

  <sys:Double x:Key="TextDisplay">32</sys:Double>
  <sys:Double x:Key="TextH1">28</sys:Double>
  <sys:Double x:Key="TextH2">24</sys:Double>
  <sys:Double x:Key="TextH3">20</sys:Double>
  <sys:Double x:Key="TextBodyLg">16</sys:Double>
  <sys:Double x:Key="TextBody">14</sys:Double>
  <sys:Double x:Key="TextBodySm">13</sys:Double>
  <sys:Double x:Key="TextCaption">11</sys:Double>

  <!-- Spacing -->
  <Thickness x:Key="Space1">4</Thickness>
  <Thickness x:Key="Space2">8</Thickness>
  <Thickness x:Key="Space3">12</Thickness>
  <Thickness x:Key="Space4">16</Thickness>
  <Thickness x:Key="Space5">20</Thickness>
  <Thickness x:Key="Space6">24</Thickness>
  <Thickness x:Key="Space8">32</Thickness>
  <Thickness x:Key="Space10">40</Thickness>
  <Thickness x:Key="Space12">48</Thickness>
  <Thickness x:Key="Space16">64</Thickness>

  <!-- Corner Radius -->
  <CornerRadius x:Key="RadiusSm">6</CornerRadius>
  <CornerRadius x:Key="RadiusMd">10</CornerRadius>
  <CornerRadius x:Key="RadiusLg">14</CornerRadius>
  <CornerRadius x:Key="RadiusXl">18</CornerRadius>
  <CornerRadius x:Key="Radius2xl">24</CornerRadius>
  <CornerRadius x:Key="RadiusFull">9999</CornerRadius>

  <!-- Shadows -->
  <sys:Double x:Key="Shadow1Blur">8</sys:Double>
  <sys:Double x:Key="Shadow1Depth">2</sys:Double>
  <sys:Double x:Key="Shadow2Blur">16</sys:Double>
  <sys:Double x:Key="Shadow2Depth">4</sys:Double>
  <sys:Double x:Key="Shadow3Blur">24</sys:Double>
  <sys:Double x:Key="Shadow3Depth">8</sys:Double>

  <!-- Transition Durations (ms) -->
  <sys:Double x:Key="DurationFast">150</sys:Double>
  <sys:Double x:Key="DurationNormal">250</sys:Double>
  <sys:Double x:Key="DurationSlow">350</sys:Double>

  <!-- Layout -->
  <sys:Double x:Key="SidebarWidth">280</sys:Double>
  <sys:Double x:Key="SidebarCollapsedWidth">64</sys:Double>
  <sys:Double x:Key="TopbarHeight">56</sys:Double>

</ResourceDictionary>
